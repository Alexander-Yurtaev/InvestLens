<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:InvestLens.Desktop.UI.ViewModels"
        xmlns:models="clr-namespace:InvestLens.Desktop.UI.Models"
        mc:Ignorable="d" d:DesignWidth="800"
        x:Class="InvestLens.Desktop.UI.Views.MainWindow"
        x:DataType="viewModels:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="InvestLens.Desktop.UI"
        Classes="mainWindow">
    
    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <viewModels:MainWindowViewModel/>
    </Design.DataContext>
    
    <Window.DataTemplates>
        <DataTemplate DataType="models:MenuItem">
            <Border Classes="menuItem">
                <Grid RowDefinitions="Auto,Auto,*,Auto">
                    <TextBlock Grid.Row="0" Text="{Binding Icon}" Classes="menuItem icon"/>
                    <TextBlock Grid.Row="1" Text="{Binding Title}" Classes="menuItem title"/>
                    <TextBlock Grid.Row="2" Text="{Binding Description}" Classes="menuItem description"/>
                    <Border Grid.Row="3" Classes="menuItem stats">
                        <ItemsControl ItemsSource="{Binding Stats}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="2" Rows="1"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </Border>
                </Grid>
            </Border>
        </DataTemplate>
        <DataTemplate DataType="models:MenuItemStat">
            <Grid ColumnDefinitions="Auto,*" Classes="menuItem stat">
                <TextBlock Grid.Column="0" Text="{Binding Icon}" Classes="menuItem stat icon"/>
                <TextBlock Grid.Column="1" Text="{Binding Title}" Classes="menuItem stat title"/>
            </Grid>
        </DataTemplate>
        <DataTemplate DataType="models:Dictionary">
            <Border Classes="dictionary">
                <Grid ColumnDefinitions="Auto,*">
                    <TextBlock Grid.Column="0" Text="{Binding Icon}" Classes="dictionary icon"/>
                    <TextBlock Grid.Column="1" Text="{Binding Title}" Classes="dictionary title"/>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.DataTemplates>

    <Window.Styles>
        <Style Selector="Window.mainWindow">
            <Style.Setters>
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#667eea" Offset="0"/>
                            <GradientStop Color="#764ba2" Offset="1"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
            </Style.Setters>
        </Style>
        <!--Common-->
        <Style Selector="TextBlock">
            <Setter Property="FontFamily" Value="'Segoe UI', 'Tahoma', 'Geneva', 'Verdana', 'sans-serif'"/>
        </Style>
        <!--Header-->
        <Style Selector="Border.header">
            <Setter Property="Background" Value="#f2ffffff"/>
            <Setter Property="Padding" Value="40,20"/>
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Margin" Value="5,0,5,30"/>
            <Setter Property="BoxShadow" Value="0 10 30 #1a000000"/>
        </Style>
        <Style Selector="TextBlock.header">
        </Style>
        <Style Selector="TextBlock.header.icon">
            <Setter Property="FontSize" Value="40"/>
            <Setter Property="Padding" Value="0,0,0,10"/>
        </Style>
        <Style Selector="TextBlock.header.title">
            <Setter Property="FontSize" Value="40"/>
            <Setter Property="Foreground" Value="#667eea"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="0,0,0,10"/>
        </Style>
        <Style Selector="TextBlock.header.subtitle">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Foreground" Value="#666"/>
        </Style>
        <!--Menu-->
        <Style Selector="Border.menu">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="5"/>
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
        </Style>
        <!--MenuItem-->
        <Style Selector="Border.menuItem">
            <Setter Property="MinWidth" Value="300"/>
            <Setter Property="MaxWidth" Value="360"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Padding" Value="30"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BoxShadow" Value="0 5 20 #1a0000"/>
        </Style>
        <Style Selector="TextBlock.menuItem.icon">
            <Setter Property="FontSize" Value="48"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>
        <Style Selector="TextBlock.menuItem.title">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
            <Setter Property="Foreground" Value="#667eea"/>
        </Style>
        <Style Selector="TextBlock.menuItem.description">
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="LineHeight" Value="26"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
            <Setter Property="TextWrapping" Value="WrapWithOverflow"/>
        </Style>
        <Style Selector="Border.menuItem.stats">
            <Setter Property="Padding" Value="0,20,0,0"/>
            <Setter Property="BorderThickness" Value="0,1,0,0"/>
            <Setter Property="BorderBrush" Value="#eee"/>
        </Style>
        <Style Selector="TextBlock.menuItem.stat">

        </Style>
        <Style Selector="TextBlock.menuItem.stat.icon">
            
        </Style>
        <Style Selector="TextBlock.menuItem.stat.title">
            <Setter Property="TextWrapping" Value="WrapWithOverflow"/>
            <Setter Property="Foreground" Value="#999"/>
            <Setter Property="FontSize" Value="16"/>
        </Style>

        <!--Dictionaries-->
        <Style Selector="Border.dictionaries">
            <Setter Property="Background" Value="#f2ffffff"/>
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Padding" Value="30"/>
            <Setter Property="Margin" Value="0 ,40,0,0"/>
        </Style>
        <Style Selector="TextBlock.dictionaries.icon">
            <Setter Property="FontSize" Value="21"/>
        </Style>
        <Style Selector="TextBlock.dictionaries.title">
            <Setter Property="FontSize" Value="21"/>
            <Setter Property="Foreground" Value="#667eea"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>

        <!--Dictionary-->
        <Style Selector="Border.dictionary">
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#f5f7fa" Offset="0"/>
                        <GradientStop Color="#c3cfe2" Offset="1"/>
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
            <Setter Property="Padding" Value="25,12"/>
            <Setter Property="CornerRadius" Value="30"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
        <Style Selector="TextBlock.dictionary.icon">
            <Setter Property="FontSize" Value="21"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
        <Style Selector="TextBlock.dictionary.title">
            <Setter Property="FontSize" Value="21"/>
            <Setter Property="Foreground" Value="#333"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto" Margin="20">
        <Border Grid.Row="0" Classes="header">
            <Grid Grid.Row="0" RowDefinitions="*,*">
                <Grid ColumnDefinitions="Auto,*">
                    <TextBlock Grid.Column="0" Text="{Binding Icon}" Classes="header icon" />
                    <TextBlock Grid.Column="1" Text="{Binding Title}" Classes="header title" />
                </Grid>
                <TextBlock Grid.Row="1" Text="{Binding Description}" Classes="header subtitle" />
            </Grid>
        </Border>
        
        <Border Grid.Row="1" Classes="menu">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding MenuItems}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" 
                                       ItemSpacing="30" 
                                       LineSpacing="30"
                                       ItemsAlignment="Center"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2" Classes="dictionaries">
            <Grid RowDefinitions="Auto,*" ColumnDefinitions="Auto,*">
                <TextBlock Grid.Column="0" Grid.Row="0" Text="📚" Classes="dictionaries icon" />
                <TextBlock Grid.Column="1" Grid.Row="0" Text="Все справочники InvestLens" Classes="dictionaries title" />
                <ItemsControl Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="2" ItemsSource="{Binding Dictionaries}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="15"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </Grid>
        </Border>
    </Grid>

</Window>
